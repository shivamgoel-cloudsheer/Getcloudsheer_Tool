# Auth.js - generate with: npx auth secret
AUTH_SECRET=

# Google OAuth client (Google Cloud Console > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Neon Postgres connection string
DATABASE_URL=

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM="CloudSheer <hello@mail.cloudsheer.com>"
# Fallback Reply-To only. Each send now replies to its own From address; the
# per-sender mapping lives in src/lib/senders.ts.
RESEND_REPLY_TO=solutions@cloudsheer.com

# Physical postal address for the email footer (CAN-SPAM) used for the default
# RESEND_FROM sender. Per-person addresses are set in src/lib/senders.ts.
MAILING_ADDRESS="CloudSheer Consulting, [STREET ADDRESS], Brooklyn, NY [ZIP], USA"

# Public base URL of the deployed app (used in unsubscribe links)
APP_URL=http://localhost:3000

# Secret for the daily cron trigger (also set in Vercel)
CRON_SECRET=

# Site-wide access password (the gate screen before anything loads)
ACCESS_PASSWORD=
