# Auth.js - generate with: npx auth secret
AUTH_SECRET=

# Google OAuth client (Google Cloud Console > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Neon Postgres connection string
DATABASE_URL=

# Sending happens through each sender's own Gmail (per-sender OAuth via the
# Google client above; each sender signs in once to grant gmail.send). The
# default sender and per-person config live in src/lib/senders.ts.

# Public base URL of the deployed app (currently unused in emails - emails no
# longer contain an app link - kept for future use)
APP_URL=http://localhost:3000

# Secret for the daily cron trigger (also set in Vercel)
CRON_SECRET=

# Site-wide access password (the gate screen before anything loads)
ACCESS_PASSWORD=
